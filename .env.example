# Copy this file to .env and fill in real values locally. Do NOT commit .env.
# LLM (Kimi / Moonshot) — runtime reads LLM_API_KEY (KIMI_API_KEY kept for reference).
KIMI_API_KEY=your-kimi-api-key-here
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=kimi-k2.6
LLM_API_KEY=your-llm-api-key-here

# MySQL Configuration
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=pptx_agent
